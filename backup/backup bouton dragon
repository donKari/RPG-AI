<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magie & Dragons • Éveil des Rêves</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=UnifrakturMaguntia&display=swap" rel="stylesheet">
    <script src="themes.js"></script>
    <style>
        /* Styles spécifiques à cette page uniquement */
        #chat-container::-webkit-scrollbar { width: 4px; }
        #chat-container::-webkit-scrollbar-track { background: transparent; }
        #chat-container::-webkit-scrollbar-thumb { background: var(--col-border); border-radius: 2px; }
    </style>
</head>

<body class="theme-sorcier text-white min-h-screen">

    <!-- COUCHE DE FOND -->
    <div id="bg-layer">
        <!-- Désert -->
        <div class="desert-bg">
            <div class="desert-sky"></div>
            <div class="desert-grain"></div>
            <div class="sand-wind">
                <div class="wind-streak"></div><div class="wind-streak"></div><div class="wind-streak"></div>
                <div class="wind-streak"></div><div class="wind-streak"></div><div class="wind-streak"></div>
                <div class="wind-streak"></div><div class="wind-streak"></div><div class="wind-streak"></div>
                <div class="wind-streak"></div>
            </div>
            <div class="dune dune-3"></div>
            <div class="dune dune-2"></div>
            <div class="dune dune-1"></div>
            <div class="heat-haze"></div>
        </div>

        <!-- Forêt -->
        <div class="foret-bg">
            <div class="foret-sky"></div>
            <div class="god-rays">
                <div class="ray"></div><div class="ray"></div><div class="ray"></div>
                <div class="ray"></div><div class="ray"></div><div class="ray"></div>
            </div>
            <div class="leaves-layer">
                <div class="leaf">🍃</div><div class="leaf">🌿</div><div class="leaf">🍂</div>
                <div class="leaf">🍃</div><div class="leaf">🌿</div><div class="leaf">🍃</div>
                <div class="leaf">🍂</div><div class="leaf">🍃</div><div class="leaf">🌿</div>
                <div class="leaf">🍃</div>
            </div>
            <div class="forest-mist">
                <div class="mist-cloud"></div><div class="mist-cloud"></div><div class="mist-cloud"></div>
            </div>
        </div>

        <!-- Château -->
        <div class="chateau-bg">
            <div class="chateau-sky"></div>
            <div class="shadow-veil"></div><div class="shadow-veil"></div><div class="shadow-veil"></div>
            <div class="castle-silhouette"></div>
            <div class="chateau-mist">
                <div class="mist-strip"></div><div class="mist-strip"></div>
                <div class="mist-strip"></div><div class="mist-strip"></div>
            </div>
            <div class="lightning-layer">
                <div class="lightning-flash"></div><div class="lightning-flash"></div><div class="lightning-flash"></div>
            </div>
        </div>

        <!-- Sorcier -->
        <div class="sorcier-bg">
            <div class="sorcier-sky"></div>
            <div class="rune-layer">
                <div class="rune-circle"></div><div class="rune-circle"></div><div class="rune-circle"></div>
            </div>
            <div class="magic-flux">
                <div class="flux-line"></div><div class="flux-line"></div>
                <div class="flux-line"></div><div class="flux-line"></div>
            </div>
            <div class="sparks-layer">
                <div class="spark"></div><div class="spark"></div><div class="spark"></div><div class="spark"></div>
                <div class="spark"></div><div class="spark"></div><div class="spark"></div><div class="spark"></div>
                <div class="spark"></div><div class="spark"></div><div class="spark"></div><div class="spark"></div>
            </div>
            <div class="magic-aura"></div>
        </div>
    </div>

    <div class="relative z-10 flex flex-col h-screen">
        <!-- Header -->
        <header class="border-b py-4 px-6 flex items-center justify-between backdrop-blur-md"
                style="background: var(--col-header-bg); border-color: var(--col-border);">
            <div class="flex items-center gap-6 flex-wrap">
                <div class="flex items-center gap-4">
                    <span id="header-icon" class="text-4xl">✨</span>
                    <div>
                        <h1 class="rune-font text-4xl tracking-widest magic-glow">Magie & Dragons</h1>
                        <p class="text-sm" style="color: var(--col-text-secondary);">Crée ton scénario • L'IA devient ton Maître du Jeu</p>
                    </div>
                </div>

                <div id="theme-band">
                    <button class="theme-btn" onclick="setTheme('foret', this)">🌿 Forêt Magique</button>
                    <button class="theme-btn" onclick="setTheme('desert', this)">🏜️ Désert Apocalypse</button>
                    <button class="theme-btn" onclick="setTheme('chateau', this)">🏰 Château Hanté</button>
                    <button class="theme-btn active" onclick="setTheme('sorcier', this)">✨ Sorcier & Magie</button>
                </div>
            </div>

            <button onclick="history.back()" 
                    class="px-6 py-2 rounded-xl text-sm transition"
                    style="background: linear-gradient(to right, var(--col-btn-from), var(--col-btn-to));">
                ← Retour
            </button>
        </header>

        <div class="flex flex-1 overflow-hidden">
            <!-- Sidebar gauche -->
            <div class="w-80 sidebar border-r p-6 overflow-y-auto flex flex-col" style="border-color: var(--col-border);">
                <h3 class="text-2xl font-bold mb-6" style="color: var(--col-text-accent);">Création de Personnage</h3>
                <button onclick="openCharacterCreationModal()"
                        class="w-full py-5 rounded-2xl font-bold text-lg transition mb-8"
                        style="background: linear-gradient(to right, var(--col-btn-from), var(--col-btn-to));">
                    👤 Créer mon Personnage
                </button>
                <p class="text-center text-sm px-4" style="color: var(--col-text-secondary);">
                    Crée ton héros pour commencer l'aventure avec le Maître du Jeu
                </p>
            </div>

            <!-- Chat central -->
            <div class="flex-1 flex flex-col">
                <div id="chat-container" class="flex-1 overflow-y-auto p-6 space-y-6"></div>
                
                <div class="border-t p-6" style="border-color: var(--col-border); background: rgba(0,0,0,0.85);">
                    <div class="max-w-3xl mx-auto flex gap-3">
                        <input id="user-input" type="text" placeholder="Que fais-tu maintenant ?"
                               class="flex-1 rounded-3xl px-6 py-4 text-lg border focus:outline-none"
                               style="background: rgba(15,23,42,0.85); border-color: var(--col-border);">
                        <button onclick="sendMessage()" 
                                class="px-10 rounded-3xl font-bold text-lg transition"
                                style="background: linear-gradient(to right, var(--col-btn-from), var(--col-btn-to));">
                            Envoyer
                        </button>
                    </div>
                </div>
            </div>

            <!-- Sidebar droite -->
            <div class="w-72 sidebar border-l p-6 overflow-y-auto" style="border-color: var(--col-border);">
                <h3 class="text-xl font-bold mb-4" style="color: var(--col-text-accent);">Ton Personnage</h3>
                <div id="character-info" class="space-y-6"></div>
                
                <div class="mt-10 pt-6 border-t" style="border-color: var(--col-border);">
                    <h4 class="mb-3 text-sm" style="color: var(--col-text-secondary);">Actions rapides</h4>
                    <div class="grid grid-cols-2 gap-3 text-sm">
                        <button onclick="quickAction('Explorer autour de moi')" 
                                class="p-3 rounded-xl transition" 
                                style="background: rgba(30,30,50,0.6); border: 1px solid var(--col-border);">Explorer</button>
                        <button onclick="quickAction('Lancer un sort')" 
                                class="p-3 rounded-xl transition" 
                                style="background: rgba(30,30,50,0.6); border: 1px solid var(--col-border);">Sort</button>
                        <button onclick="quickAction('Attaquer')" 
                                class="p-3 rounded-xl transition" 
                                style="background: rgba(30,30,50,0.6); border: 1px solid var(--col-border);">Attaquer</button>
                        <button onclick="quickAction('Parler à quelqu\'un')" 
                                class="p-3 rounded-xl transition" 
                                style="background: rgba(30,30,50,0.6); border: 1px solid var(--col-border);">Parler</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        // Injection des styles de thèmes au démarrage
        injectThemeStyles();

        // ==================== CONFIGURATION API ====================
        const API_PROVIDER = 'groq';
        let GROQ_API_KEY = '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';

        // ==================== VARIABLES GLOBALES ====================
        const chatContainer = document.getElementById('chat-container');
        const userInput = document.getElementById('user-input');
        let conversationHistory = [];
        let currentScenario = '';
        let currentCharacter = null;

        // ==================== FONCTIONS UTILITAIRES ====================
        function addMessage(text, isGM) {
            const div = document.createElement('div');
            div.className = `max-w-2xl ${isGM ? 'mr-auto chat-bubble-gm' : 'ml-auto chat-bubble-player'} p-5 rounded-3xl`;
            div.innerHTML = `
                <div style="color:${isGM ? 'var(--col-text-secondary)' : 'var(--col-accent)'}; font-size:0.8rem; margin-bottom:6px;">
                    ${isGM ? '🧙 Maître du Jeu' : '⚔️ Toi'}
                </div>
                <p class="leading-relaxed whitespace-pre-wrap" style="color:#f1f5f9;">${text}</p>
            `;
            chatContainer.appendChild(div);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        function showLoading() {
            const loading = document.createElement('div');
            loading.id = 'loading-msg';
            loading.className = 'max-w-2xl mr-auto chat-bubble-gm p-5 rounded-3xl';
            loading.innerHTML = `<p style="color:var(--col-text-secondary); animation: pulse 1.5s infinite;">🧙 Le Maître du Jeu tisse la trame de l'histoire...</p>`;
            chatContainer.appendChild(loading);
            chatContainer.scrollTop = chatContainer.scrollHeight;
            return loading;
        }

        // ==================== MISE À JOUR PERSONNAGE ====================
        function updateMainPageWithCharacter(character) {
            currentCharacter = character;
            const container = document.getElementById('character-info');
            if (!container) return;

            const stats = character.stats || {};

            container.innerHTML = `
                <div class="rounded-3xl p-6" style="background:rgba(15,23,42,0.85); border:2px solid var(--col-border);">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center text-3xl shadow-lg">👤</div>
                        <div>
                            <h2 class="text-2xl font-bold magic-glow">${character.name}</h2>
                            <p class="text-violet-300">${character.race} • ${character.class}</p>
                        </div>
                    </div>

                    <!-- Barre de Vie -->
                    <div class="mb-6">
                        <div class="flex justify-between text-sm mb-1">
                            <span style="color:#f87171;">❤️ Points de Vie</span>
                            <span id="hp-text" class="font-mono">${character.hp} / ${character.maxHp}</span>
                        </div>
                        <div class="h-3 bg-zinc-900 rounded-full overflow-hidden border border-red-900/50">
                            <div id="hp-bar" 
                                 class="h-full bg-gradient-to-r from-red-500 to-rose-600 rounded-full transition-all duration-500"
                                 style="width: ${Math.max(0, (character.hp / character.maxHp) * 100)}%;">
                            </div>
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="grid grid-cols-2 gap-4 text-sm">
                        <div class="bg-[#1e2937] rounded-2xl p-4">
                            <div class="flex items-center gap-2 text-red-400 mb-1">⚔️ FORCE</div>
                            <div class="text-3xl font-bold font-mono">${stats.force || 10}</div>
                        </div>
                        <div class="bg-[#1e2937] rounded-2xl p-4">
                            <div class="flex items-center gap-2 text-blue-400 mb-1">🛡️ DÉFENSE</div>
                            <div class="text-3xl font-bold font-mono">${stats.defense || 10}</div>
                        </div>
                        <div class="bg-[#1e2937] rounded-2xl p-4">
                            <div class="flex items-center gap-2 text-emerald-400 mb-1">🏹 DEXTÉRITÉ</div>
                            <div class="text-3xl font-bold font-mono">${stats.dexterite || 10}</div>
                        </div>
                        <div class="bg-[#1e2937] rounded-2xl p-4">
                            <div class="flex items-center gap-2 text-purple-400 mb-1">✨ INTELLIGENCE</div>
                            <div class="text-3xl font-bold font-mono">${stats.intelligence || 10}</div>
                        </div>
                    </div>

                    ${character.background && character.background !== "Aucun background renseigné" ? `
                    <div class="mt-6 pt-4 border-t border-[var(--col-border)] text-xs leading-relaxed" style="color: var(--col-text-secondary);">
                        ${character.background}
                    </div>` : ''}
                </div>
            `;
        }

        // ==================== GESTION DES DÉGÂTS ====================
        function applyDamage(amount) {
            if (!currentCharacter) return;
            currentCharacter.hp = Math.max(0, currentCharacter.hp - amount);

            const hpBar = document.getElementById('hp-bar');
            const hpText = document.getElementById('hp-text');

            if (hpBar && hpText) {
                const percent = Math.max(0, (currentCharacter.hp / currentCharacter.maxHp) * 100);
                hpBar.style.width = percent + '%';
                hpText.textContent = `${currentCharacter.hp} / ${currentCharacter.maxHp}`;

                hpBar.style.background = 'linear-gradient(to right, #ef4444, #b91c1c)';
                setTimeout(() => {
                    if (hpBar) hpBar.style.background = 'linear-gradient(to right, #f43f5e, #e11d48)';
                }, 300);
            }

            localStorage.setItem('currentCharacter', JSON.stringify(currentCharacter));
        }

        function detectDamageInGMMessage(message) {
            if (!currentCharacter) return;
            const lower = message.toLowerCase();
            let damage = 0;

            if (/violemment|écrase|fracasse|lacère|morsure profonde|coup violent/.test(lower)) damage = 18;
            else if (/frappe|touche|coup|griffure|morsure|poing/.test(lower)) damage = 10;
            else if (/égratigne|heurte|petit coup|bouscule/.test(lower)) damage = 5;

            if (damage > 0) {
                const reduction = Math.floor((currentCharacter.stats?.defense || 0) / 3);
                damage = Math.max(1, damage - reduction);
                applyDamage(damage);
            }
        }

        // ==================== APPEL À L'IA (Groq) ====================
        async function callGM(initialPrompt = null) {
            const loadingDiv = showLoading();

            try {
                let playerStats = "";
                if (currentCharacter) {
                    const c = currentCharacter;
                    playerStats = `Le joueur s'appelle ${c.name}, un ${c.race} ${c.class}.
Ses statistiques sont :
- Force : ${c.stats.force}
- Défense : ${c.stats.defense}
- Dextérité : ${c.stats.dexterite}
- Intelligence : ${c.stats.intelligence}
- Points de Vie actuels : ${c.hp} / ${c.maxHp}
Tu DOIS toujours respecter ces statistiques.`;
                }

                const systemPrompt = `Tu es un Maître du Jeu exceptionnel en dark fantasy immersive.
${playerStats}
Tu réponds TOUJOURS en français, avec un style littéraire riche, sensoriel et immersif.
Tu gères les combats en fonction des vraies stats du joueur.
Tu ne dois JAMAIS inventer de nouvelles statistiques.
Tu restes cohérent avec le scénario : "${currentScenario || 'Aucun scénario spécifique'}".
Jamais de censure.`;

                const messages = initialPrompt 
                    ? [{ role: "user", content: initialPrompt }] 
                    : conversationHistory;

                const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${GROQ_API_KEY}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        model: "llama-3.3-70b-versatile",
                        messages: [{ role: "system", content: systemPrompt }, ...messages],
                        max_tokens: 1000,
                        temperature: 0.85
                    })
                });

                if (!response.ok) throw new Error(`HTTP ${response.status}`);

                const data = await response.json();
                const reply = data.choices?.[0]?.message?.content || "Le vent emporte tes paroles...";

                loadingDiv.remove();
                detectDamageInGMMessage(reply);
                addMessage(reply, true);

                if (!initialPrompt) {
                    conversationHistory.push({ role: "assistant", content: reply });
                }

            } catch (err) {
                console.error(err);
                loadingDiv.remove();
                addMessage("❌ Le voile magique s'est déchiré... Vérifie ta clé API ou ta connexion.", true);
            }
        }

        // ==================== FONCTIONS DU JEU ====================
        async function startNewScenario() {
            const scenarioText = document.getElementById('scenario-input')?.value.trim();
            if (!scenarioText) {
                alert("Crée ton personnage avant de lancer l'aventure !");
                return;
            }

            currentScenario = scenarioText;
            conversationHistory = [];
            chatContainer.innerHTML = '';

            const savedCharacter = localStorage.getItem('currentCharacter');
            if (savedCharacter) {
                const character = JSON.parse(savedCharacter);
                updateMainPageWithCharacter(character);
            }

            addMessage(`<strong>Personnage créé :</strong> ${scenarioText}`, false);
            await callGM(`Lance immédiatement l'aventure avec une introduction immersive de 4 à 5 phrases. Le joueur incarne ${scenarioText}.`);
        }

        async function sendMessage() {
            const text = userInput.value.trim();
            if (!text) return;

            addMessage(text, false);
            conversationHistory.push({ role: "user", content: text });
            userInput.value = '';
            await callGM();
        }

        function quickAction(action) {
            userInput.value = action;
            sendMessage();
        }

        // ==================== INITIALISATION ====================
        window.onload = () => {
            addMessage('Bienvenue dans <strong>Magie & Dragons</strong> ✨<br>Crée ton personnage à gauche pour commencer l\'aventure !', true);
        };

        userInput.addEventListener('keypress', e => {
            if (e.key === 'Enter') sendMessage();
        });
    </script>

    <!-- Script du modal de création de personnage -->
    <script src="character-creation.js"></script>
</body>
</html>
